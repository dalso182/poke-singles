# Copy to .env.local (gitignored) and fill in. Used by scripts/deploy.mjs.
#
# Two deploy targets are supported via the `--env=prod|dev` flag:
#   prod (default) — uses the unprefixed keys, deploys to <prod-domain>
#   dev            — uses the DEV_-prefixed keys, deploys to <dev-subdomain>
#
# Both can share the same SiteGround SSH user and SSH key — only the remote
# directory differs. The `npm run deploy:prod` / `npm run deploy:dev` scripts
# wrap the right --env flag.

# --- Prod (poke-singles.com) ---
DEPLOY_HOST=<your-siteground-ssh-host>
DEPLOY_PORT=18765
DEPLOY_USER=<your-ssh-user>
DEPLOY_REMOTE_DIR=/home/customer/www/poke-singles.com/public_html

# Auth: either DEPLOY_PASSWORD or the private-key pair.
# DEPLOY_PASSWORD=...
DEPLOY_PRIVATE_KEY_PATH=C:\Users\diego\.ssh\siteground_poke_singles
DEPLOY_PRIVATE_KEY_PASSPHRASE=...

# --- Dev (dev.poke-singles.com or similar staging subdomain) ---
DEV_DEPLOY_HOST=<your-siteground-ssh-host>
DEV_DEPLOY_PORT=18765
DEV_DEPLOY_USER=<your-ssh-user>
DEV_DEPLOY_REMOTE_DIR=/home/customer/www/dev.poke-singles.com/public_html
DEV_DEPLOY_PRIVATE_KEY_PATH=C:\Users\diego\.ssh\siteground_poke_singles
DEV_DEPLOY_PRIVATE_KEY_PASSPHRASE=...

# --- Self-hosted card images (scripts/upload-images.mjs) ---
# Where scripts/upload-images.mjs drops the TCGdex image tree. Optional: if unset,
# it defaults to <DEV_DEPLOY_REMOTE_DIR>/card-images (or <DEPLOY_REMOTE_DIR>/card-images
# with --env=prod). Must end in /card-images — the script refuses anything else so it
# can never write into the app root. Served at <domain>/card-images/..., referenced by
# relative path (/card-images/<serie>/<set>/<localId>.webp) so it survives the cutover.
# IMAGES_REMOTE_DIR=/home/customer/www/dev.poke-singles.com/public_html/card-images

# --- Localhost card-image proxy (proxy.conf.mjs, dev only) ---
# The staging subdomain is HTTP-Basic password-protected, so on localhost the dev
# server proxies /card-images to it with these credentials. Set them to the site
# password you configured in SiteGround, then restart `npm start`. Only used by
# `ng serve` — production never proxies (images are same-origin there).
# IMAGES_HTTP_USER=
# IMAGES_HTTP_PASSWORD=

# --- Supabase service role (offline scripts) ---
# Service role / secret keys bypass RLS — server-side scripts only, never the
# browser bundle. Find them in Supabase dashboard → Project Settings → API Keys.
#
# PROD project (dhslfridsjdmhwzrgebv, Pro org) — used by one-off admin scripts
# and scripts/db-push-prod.mjs. Treat with production care.
SUPABASE_PROD_URL=https://dhslfridsjdmhwzrgebv.supabase.co
SUPABASE_PROD_SERVICE_ROLE_KEY=
# Connection string for `npm run db:push:prod` (Dashboard → Connect → Session pooler).
# Deliberately separate from the CLI link, which points at DEV for daily work.
# SUPABASE_PROD_DB_URL=postgresql://postgres.dhslfridsjdmhwzrgebv:<db-password>@<pooler-host>:5432/postgres
#
# DEV project (fdscdinfpmvswinpasdg, free org) — used by scripts/seed-products.mjs
# and the e2e seed/cleanup scripts.
SUPABASE_DEV_URL=https://fdscdinfpmvswinpasdg.supabase.co
SUPABASE_DEV_SERVICE_ROLE_KEY=
